{
    "name": "medzuch/jwt-php",
    "description": "Standalone, RFC 7519 / 7797 / 8725-compliant JWT library for PHP 8.3+. Framework-agnostic.",
    "type": "library",
    "license": "MIT",
    "keywords": ["jwt", "jws", "jwe", "jose", "rfc7519", "rfc8725", "security", "auth"],
    "authors": [
        {
            "name": "Marcin Mech",
            "email": "marcin.mech@gmail.com"
        }
    ],
    "require": {
        "php": "~8.3.0",
        "ext-json": "*",
        "ext-openssl": "*",
        "ext-sodium": "*",
        "ext-mbstring": "*",
        "psr/clock": "^1.0"
    },
    "suggest": {
        "psr/log": "^3.0 — required to use the PSR-3 logging hooks (planned for Phase 5).",
        "psr/simple-cache": "^3.0 — required by RemoteJwksResolver for JWKS caching (planned for Phase 2).",
        "psr/http-client": "^1.0 — required by RemoteJwksResolver to fetch a jwks_uri (planned for Phase 2).",
        "psr/http-factory": "^1.0 — required by RemoteJwksResolver to build PSR-7 requests (planned for Phase 2)."
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.95",
        "infection/infection": "^0.29",
        "roave/security-advisories": "dev-latest",
        "nyholm/psr7": "^1.8",
        "symfony/http-client": "^7.3"
    },
    "autoload": {
        "psr-4": {
            "Medzuch\\Jwt\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Medzuch\\Jwt\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=unit",
        "test:integration": "phpunit --testsuite=integration",
        "test:conformance": "phpunit --testsuite=conformance",
        "test:coverage": "XDEBUG_MODE=coverage phpunit --coverage-html=var/coverage --coverage-text",
        "test:mutation": "infection --threads=max --min-msi=85 --min-covered-msi=90",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "phpstan:baseline": "phpstan analyse --generate-baseline --memory-limit=512M",
        "cs:check": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "qa": [
            "@cs:check",
            "@phpstan",
            "@test"
        ],
        "qa:full": [
            "@cs:check",
            "@phpstan",
            "@test:coverage",
            "@test:mutation"
        ]
    },
    "scripts-descriptions": {
        "test": "Run the full PHPUnit suite",
        "test:coverage": "Run tests with HTML coverage report at var/coverage",
        "test:mutation": "Run Infection mutation tests (slow, CI only)",
        "phpstan": "Run static analysis at level 9",
        "cs:check": "Check code style without fixing",
        "cs:fix": "Apply code-style fixes",
        "qa": "Fast quality gate (style + phpstan + tests)",
        "qa:full": "Full quality gate including coverage and mutation testing"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "infection/extension-installer": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
